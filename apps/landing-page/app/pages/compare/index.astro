---
/*
 * /compare/ — evaluation-stage comparison hub.
 *
 * Captures "open design vs <competitor>" queries with honest summary
 * cards that link out to per-competitor detail pages (today: just the
 * primary Claude Design alternative page; others will follow as
 * `/alternatives/<slug>/`).
 *
 * Honest-limitations block at the bottom is required by §8 of the
 * SEO plan — comparison pages without a limitation section read as
 * adversarial and tank trust.
 */
import Layout from '../../_components/sub-page-layout.astro';
import { localeFromPath, localizedHref } from '../../i18n';

// Derive SITE from Astro.site so preview/staging deploys produce JSON-LD
// that matches the layout's `canonical` link. Falls back to the
// production origin so a missing `site` config never emits a broken URL.
const SITE = Astro.site?.toString() ?? 'https://open-design.ai/';
const locale = localeFromPath(Astro.url.pathname);
const href = (path: string) => localizedHref(path, locale);

const title = 'Open Design vs Claude Design, Figma Make, v0, Lovable — honest comparison';
const description =
  'Compare Open Design to the major AI design tools. Hosted vs local-first, BYOK vs vendor-locked, single-shot generation vs portable DESIGN.md systems. Includes an honest limitations section.';

// Honest-limits FAQ — visible at the bottom of the page AND emitted as
// FAQPage JSON-LD. Google requires schema entries to mirror visible
// content; converting our "what we don't do" prose into question form
// gives us a shot at the People Also Ask rich result on comparison
// queries.
const limitsFaq = [
  {
    q: 'Does Open Design offer a hosted web sandbox?',
    a: 'No. Open Design is local-first by design — the daemon, web UI, and skill runtime all run on your machine. If you need a one-click hosted sandbox with zero local install, the hosted competitors on this page are a better fit for that use case.',
  },
  {
    q: 'Can I use Open Design without installing anything?',
    a: 'Not today. The minimum is a local daemon plus a coding agent (Claude Code, Codex, Cursor, Gemini CLI, GitHub Copilot, Grok, Hermes, Kimi, Pi, Devin, OpenCode, Qwen, DeepSeek, Vibe, Kiro, Kilo, or Qoder). Open Design embraces the local install on purpose; design artifacts live as files in your project, not documents in a vendor cloud.',
  },
  {
    q: 'Is Open Design a v0 / Lovable / Bolt replacement?',
    a: 'It depends on your use case. v0, Lovable, and Bolt focus on prompt-to-app on a hosted sandbox. Open Design focuses on prompt-to-design-artifact (decks, dashboards, landing pages, brand systems, prototypes) via a skill protocol you can fork. Many teams use both: hosted full-app generators for prototyping, Open Design for design system + artifact production.',
  },
  {
    q: 'Does Open Design send my data to Anthropic, OpenAI, or Google?',
    a: 'Only your prompt + skill context goes to the provider whose key you brought (BYOK). No design output is forwarded to any Open Design server — there isn\'t one. The same applies to every supported agent: the daemon talks to your chosen provider with your credentials.',
  },
  {
    q: 'Can I self-host Open Design on my own infrastructure?',
    a: 'Yes. Apache-2.0 license, Node 24 daemon, no required SaaS. Run the daemon on your own machine, your own server, or your team\'s shared host; ship the desktop app as-is or fork the repo and rebrand it for your studio.',
  },
];

const comparisons = [
  {
    competitor: 'Claude Design',
    href: href('/alternatives/claude-design/'),
    summary:
      'Hosted product tied to a single vendor. Open Design is local-first, BYOK, and Apache-2.0 — your skills and DESIGN.md live in your repo.',
    cta: 'Read the full comparison →',
  },
  {
    competitor: 'Figma Make',
    href: 'https://github.com/nexu-io/open-design',
    summary:
      'Figma Make focuses on prompt-to-mockup inside Figma. Open Design ships portable HTML/React/PDF artifacts directly into your project, driven by the agent already on your laptop.',
    cta: 'See the repo for migration notes →',
  },
  {
    competitor: 'v0 by Vercel',
    href: 'https://github.com/nexu-io/open-design',
    summary:
      'v0 generates React components on a hosted runtime. Open Design generates any artifact (decks, dashboards, landing pages, brand systems) on your local runtime, with skills you can fork and edit as Markdown.',
    cta: 'See the repo for migration notes →',
  },
  {
    competitor: 'Lovable / Bolt',
    href: 'https://github.com/nexu-io/open-design',
    summary:
      'Lovable and Bolt focus on prompt-to-app on a hosted sandbox. Open Design is the design-skill layer for an agent you already use — it complements full-app generators rather than replacing them.',
    cta: 'See the repo for migration notes →',
  },
  {
    competitor: 'Open CoDesign',
    href: 'https://github.com/nexu-io/open-design',
    summary:
      'Open CoDesign is a sibling open-source project. Open Design is compatible: its skill protocol can wrap Open CoDesign workflows, and we recommend using them together for codesign-style sessions.',
    cta: 'See the repo for migration notes →',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Open Design', item: SITE },
      { '@type': 'ListItem', position: 2, name: 'Compare', item: `${SITE}compare/` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: `${SITE}compare/`,
    isPartOf: { '@id': `${SITE}#website` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': `${SITE}compare/#limits-faq`,
    mainEntity: limitsFaq.map(({ q, a }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: { '@type': 'Answer', text: a },
    })),
  },
];
---

<Layout title={title} description={description} active="home" jsonLd={jsonLd}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href={href('/')}>Open Design</a>
    <span>/</span>
    <span aria-current="page">Compare</span>
  </nav>

  <article class="info-page">
    <header class="catalog-head">
      <span class="label">Evaluation · Nº 02</span>
      <h1 class="display">
        Open Design vs <em>everything else</em><span class="dot">.</span>
      </h1>
      <p class="lead">
        Short, honest summaries of how Open Design relates to the other AI
        design tools you might be evaluating. Each summary links to a
        deeper comparison — or, where one doesn't exist yet, to the
        GitHub repo where the migration notes live.
      </p>
    </header>

    <nav class="info-toc" aria-label="On this page">
      <span>On this page:</span>
      <a href="#claude-design">vs Claude Design</a>
      <a href="#figma-make">vs Figma Make</a>
      <a href="#v0">vs v0</a>
      <a href="#lovable-bolt">vs Lovable / Bolt</a>
      <a href="#open-codesign">vs Open CoDesign</a>
      <a href="#limits">Honest limits</a>
    </nav>

    <section class="info-section">
      <ul class="compare-grid">
        {comparisons.map((c) => {
          const id =
            c.competitor === 'Claude Design'
              ? 'claude-design'
              : c.competitor === 'Figma Make'
              ? 'figma-make'
              : c.competitor === 'v0 by Vercel'
              ? 'v0'
              : c.competitor === 'Lovable / Bolt'
              ? 'lovable-bolt'
              : 'open-codesign';
          const isInternal = c.href.startsWith('/');
          return (
            <li class="compare-card" id={id}>
              <h3>Open Design vs <em>{c.competitor}</em></h3>
              <p>{c.summary}</p>
              <a
                href={c.href}
                target={isInternal ? undefined : '_blank'}
                rel={isInternal ? undefined : 'noreferrer noopener'}
              >
                {c.cta}
              </a>
            </li>
          );
        })}
      </ul>
    </section>

    <section class="info-section" id="limits">
      <h2>Honest <em>limits</em> — what Open Design isn't</h2>
      <p>
        Open Design isn't trying to be every hosted AI design tool. The
        questions below are the ones that recur in Discord and GitHub
        issues from evaluators; the answers describe the trade-offs
        instead of glossing them.
      </p>
      <ol class="faq-list">
        {limitsFaq.map(({ q, a }, idx) => (
          <li class="faq-item">
            <details>
              <summary>
                <span class="faq-index">{String(idx + 1).padStart(2, '0')}</span>
                <span class="faq-q">{q}</span>
                <span class="faq-toggle" aria-hidden="true">+</span>
              </summary>
              <p class="faq-a">{a}</p>
            </details>
          </li>
        ))}
      </ol>
    </section>
  </article>
</Layout>
