---
/*
 * /alternatives/claude-design/ — primary commercial-intent page.
 *
 * This is the highest-leverage SEO surface per
 * `growth/seo-opendesigner-analysis.md` §8. Captures "claude design
 * alternative", "open source claude design", and
 * "claude design vs open design" queries.
 *
 * Structure follows the spec: TL;DR, why-people-search, local-first +
 * BYOK explanation, feature comparison table, who-should-use-which,
 * migration / first run, and a visible FAQ that matches FAQPage JSON-LD.
 */
import Layout from '../../../_components/sub-page-layout.astro';
import { localeFromPath, localizedHref } from '../../../i18n';

// Derive SITE from Astro.site so preview/staging JSON-LD matches the
// layout's canonical link. Falls back to the production origin.
const SITE = Astro.site?.toString() ?? 'https://open-design.ai/';
const REPO = 'https://github.com/nexu-io/open-design';
const REPO_RELEASES = `${REPO}/releases`;
const locale = localeFromPath(Astro.url.pathname);
const href = (path: string) => localizedHref(path, locale);

const title = 'Open-source Claude Design alternative — Open Design (BYOK, local-first)';
const description =
  'Open Design is the open-source, local-first alternative to Claude Design. BYOK with Claude Code, Codex, Cursor, Gemini, OpenCode, or Qwen. Portable DESIGN.md systems, composable SKILL.md skills, Apache-2.0. Includes feature comparison table and migration guide.';

const features = [
  { name: 'License', od: 'Apache-2.0, full source on GitHub', cd: 'Closed-source, hosted product' },
  { name: 'Runtime', od: 'Local daemon on your machine', cd: 'Vendor cloud' },
  { name: 'Agent', od: 'BYOK — Claude Code, Codex, Cursor, Gemini, OpenCode, Qwen', cd: 'Vendor-managed agent' },
  { name: 'API spend', od: 'Bills to your account', cd: 'Bundled into vendor subscription' },
  { name: 'Design system', od: 'Portable DESIGN.md in your repo', cd: 'Stored in vendor DB' },
  { name: 'Skills', od: 'Composable SKILL.md — fork, edit, ship', cd: 'Built-in templates' },
  { name: 'Self-host', od: 'Yes — run anywhere Node 24 runs', cd: 'No' },
  { name: 'Pricing', od: 'Free (Apache-2.0) — you pay agent API costs', cd: 'Vendor subscription' },
  { name: 'Embed in CLI / CI', od: 'Yes via `od` CLI + HTTP daemon', cd: 'Web UI only' },
  { name: 'Artifact ownership', od: 'Files in your project directory', cd: 'Vendor-hosted documents' },
];

const faq = [
  {
    q: 'Is Open Design really a drop-in alternative to Claude Design?',
    a: 'Not literally drop-in — Open Design and Claude Design have different architectures (local-first vs hosted, BYOK vs vendor-managed agent). But they overlap on the use case: generating high-quality design artifacts from natural-language prompts. Most users who switch move because they want local data ownership, BYOK economics, or both.',
  },
  {
    q: 'Can I use Claude as my agent in Open Design?',
    a: 'Yes. Open Design supports Claude Code natively and can call the Anthropic API directly. You bring your Anthropic key; the daemon never proxies it through a vendor cloud.',
  },
  {
    q: 'What happens to my Claude Design designs?',
    a: 'You can keep using Claude Design alongside Open Design. There is no automatic migration today — but because Open Design design systems live as DESIGN.md in your repo, you can recreate a brand once and reuse it across every skill, instead of re-prompting per artifact.',
  },
  {
    q: 'Does Open Design generate the same artifact types?',
    a: 'Yes for the common ones — landing pages, decks, dashboards, social posts, brand systems, prototypes. The skill catalog at /skills/ enumerates every type currently shipping. New skills are Markdown bundles, so adding an artifact type takes a SKILL.md PR rather than a vendor feature request.',
  },
  {
    q: 'Why "open-source Claude Design" vs "open-source AI design tool"?',
    a: 'Both descriptions fit. We use "open-source Claude Design alternative" because that is how most users searching for an Open Design–shaped product describe what they want. Internally we think of the product as a skill layer for the agent already on your laptop.',
  },
  {
    q: 'Who builds and maintains Open Design?',
    a: 'The project lives at github.com/nexu-io/open-design. See the /official/ page for canonical links and the maintainer identity. The license is Apache-2.0.',
  },
];

const jsonLd = [
  {
    // Two-level breadcrumb only. There is no real `/alternatives/`
    // index page today, so we don't fabricate a middle node — both
    // the JSON-LD and the visible nav point straight from the home
    // surface to this leaf. Mirror this if/when `/alternatives/`
    // becomes a real index page.
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Open Design', item: SITE },
      { '@type': 'ListItem', position: 2, name: 'Open-source Claude Design alternative', item: `${SITE}alternatives/claude-design/` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: `${SITE}alternatives/claude-design/`,
    isPartOf: { '@id': `${SITE}#website` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map(({ q, a }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: { '@type': 'Answer', text: a },
    })),
  },
];
---

<Layout title={title} description={description} active="home" jsonLd={jsonLd}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href={href('/')}>Open Design</a>
    <span>/</span>
    <span aria-current="page">Open-source Claude Design alternative</span>
  </nav>

  <article class="info-page">
    <header class="catalog-head">
      <span class="label">Alternative · Nº 03</span>
      <h1 class="display">
        Open-source <em>Claude Design</em> alternative<span class="dot">.</span>
      </h1>
      <p class="lead">
        Open Design is the official open-source, local-first alternative
        to Claude Design. BYOK with the agent you already use, keep your
        brand as a portable <code>DESIGN.md</code> file, ship artifacts
        as files in your project — not documents in a vendor cloud.
      </p>
    </header>

    <div class="tldr-card">
      <h3>TL;DR</h3>
      <p>
        Same use case (prompt-to-design-artifact), different posture:
        <strong>local-first</strong>, <strong>BYOK</strong>,
        <strong>open source (Apache-2.0)</strong>, with portable
        <code>DESIGN.md</code> systems and composable <code>SKILL.md</code> skills.
      </p>
    </div>

    <nav class="info-toc" aria-label="On this page">
      <span>On this page:</span>
      <a href="#why-search">Why people search</a>
      <a href="#local-byok">Local-first + BYOK</a>
      <a href="#compare">Feature comparison</a>
      <a href="#who">Who should pick which</a>
      <a href="#migrate">Migration / first run</a>
      <a href="#faq">FAQ</a>
    </nav>

    <section class="info-section" id="why-search">
      <h2>Why people search for a <em>Claude Design alternative</em></h2>
      <p>Five reasons keep showing up in support threads, GitHub discussions, and Discord:</p>
      <ol>
        <li><strong>Data ownership.</strong> Designs should live as files in a repo, not documents in a vendor DB.</li>
        <li><strong>BYOK economics.</strong> Bring your own Anthropic / OpenAI / Google key; API spend bills to your account.</li>
        <li><strong>Agent choice.</strong> Drive design from Claude Code, Codex, Cursor, Gemini CLI, OpenCode, or Qwen — whatever you already use for code.</li>
        <li><strong>Brand portability.</strong> One <code>DESIGN.md</code> file encodes a brand for every skill and outlives any single tool.</li>
        <li><strong>Self-host / fork.</strong> Apache-2.0, full source — rebrand it for your studio or company.</li>
      </ol>
    </section>

    <section class="info-section" id="local-byok">
      <h2>Local-first + <em>BYOK</em>, explained</h2>
      <p>
        Open Design runs three things on your machine: a desktop app, a
        local daemon (the <code>od</code> CLI), and the skill/system
        catalogs as Markdown files. The daemon is the only thing your
        agent talks to; the agent talks to your provider (Anthropic,
        OpenAI, Google, etc.) with <em>your</em> key.
      </p>
      <p>
        No design output is forced through a vendor cloud. No credentials
        leave your machine — they sit in <code>.od/media-config.json</code>
        and a few env vars, both ignored by git. If you switch providers
        next month, you swap a key, not the whole tool.
      </p>
    </section>

    <section class="info-section" id="compare">
      <h2>Feature <em>comparison</em></h2>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th>Feature</th>
              <th>Open Design</th>
              <th>Claude Design</th>
            </tr>
          </thead>
          <tbody>
            {features.map((f) => (
              <tr>
                <th scope="row">{f.name}</th>
                <td class="yes"><span class="check">●</span>{f.od}</td>
                <td>{f.cd}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="info-section" id="who">
      <h2>Who should pick <em>which</em></h2>
      <h3>Pick Claude Design if</h3>
      <ul>
        <li>You want zero local setup and a single-vendor billing relationship.</li>
        <li>You're already deep in a Claude-first workflow and don't need agent choice.</li>
        <li>Your team is non-technical and prefers a hosted UI over Markdown files.</li>
      </ul>
      <h3>Pick Open Design if</h3>
      <ul>
        <li>You want design artifacts as files in your repo, version-controlled.</li>
        <li>You want BYOK with Claude Code, Codex, Cursor, Gemini, OpenCode, or Qwen.</li>
        <li>You want to fork the tool, rebrand it, embed it in a CLI, or self-host it.</li>
        <li>You want one <code>DESIGN.md</code> per brand that every skill respects.</li>
      </ul>
    </section>

    <section class="info-section" id="migrate">
      <h2>Migration / first run</h2>
      <p>
        There is no automatic import from Claude Design today; we
        recommend a one-time brand-extraction run:
      </p>
      <ol>
        <li>Install Open Design — see <a class="inline-link" href={href('/quickstart/')}>/quickstart/</a> (three commands).</li>
        <li>Open the web UI, point your agent at one Claude Design artifact you like, and ask it to extract the brand into a <code>DESIGN.md</code> file.</li>
        <li>Save that <code>DESIGN.md</code> into your repo under <code>design-systems/&lt;your-brand&gt;/</code>.</li>
        <li>Pick a skill from <a class="inline-link" href={href('/skills/')}>/skills/</a> and render it against your new brand — the agent uses the saved <code>DESIGN.md</code> as the brand contract.</li>
      </ol>
      <p>
        From then on, every skill renders in your brand without
        re-prompting. The <a class="inline-link" href={REPO_RELEASES} target="_blank" rel="noreferrer noopener">latest release</a>
        ships with a starter brand if you want to skip the extraction
        step on the first run.
      </p>
    </section>

    <section class="info-section" id="faq">
      <h2>FAQ</h2>
      <ol class="faq-list">
        {faq.map(({ q, a }, idx) => (
          <li class="faq-item">
            <details>
              <summary>
                <span class="faq-index">{String(idx + 1).padStart(2, '0')}</span>
                <span class="faq-q">{q}</span>
                <span class="faq-toggle" aria-hidden="true">+</span>
              </summary>
              <p class="faq-a">{a}</p>
            </details>
          </li>
        ))}
      </ol>
    </section>

    <section class="info-cta" aria-label="Open Design call to action">
      <div>
        <h2>Switch in <em>three commands</em>.</h2>
        <p>
          Star the repo, grab the desktop build, or run the install in
          your terminal. Your DESIGN.md system stays in your repo from
          the first render onward.
        </p>
      </div>
      <div class="info-cta-actions">
        <a class="btn btn-primary" href={REPO} target="_blank" rel="noreferrer noopener">Star on GitHub</a>
        <a class="btn btn-ghost" href={href('/quickstart/')}>Quickstart</a>
        <a class="btn btn-ghost" href={REPO_RELEASES} target="_blank" rel="noreferrer noopener">Download desktop</a>
      </div>
      <div class="info-cta-meta">
        <span class="stamp">● Apache-2.0</span>
        <span>Local-first · BYOK</span>
        <span>macOS · Windows · Linux</span>
      </div>
    </section>
  </article>
</Layout>
