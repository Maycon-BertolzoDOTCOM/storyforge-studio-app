---
/*
 * /quickstart/ — install-and-run intent.
 *
 * Captures "open design install", "open design quickstart",
 * "open-design getting started", "od cli" queries and lands them
 * directly on a page that gives commands, expected output, and the
 * troubleshooting checklist most users need.
 *
 * HowTo JSON-LD describes the three visible install steps; the rest
 * of the page is reference material that complements the GitHub
 * README without duplicating it.
 */
import Layout from '../../_components/sub-page-layout.astro';
import { getGithubRepoMeta } from '../../_lib/github';
import { localeFromPath, localizedHref } from '../../i18n';
import { heroImage } from '../../image-assets';

const github = await getGithubRepoMeta();
const locale = localeFromPath(Astro.url.pathname);
const href = (path: string) => localizedHref(path, locale);

// Derive SITE from Astro.site so preview/staging JSON-LD matches the
// layout's canonical link. Falls back to the production origin.
const SITE = Astro.site?.toString() ?? 'https://open-design.ai/';
const REPO = 'https://github.com/nexu-io/open-design';
const REPO_RELEASES = `${REPO}/releases`;
const QUICKSTART_DOC = `${REPO}/blob/main/QUICKSTART.md`;

// Google's HowTo rich result is image-biased: a HowTo with no images is
// near-invisible in the SERP. We attach the canonical homepage hero as
// the top-level HowTo image and reuse it per-step as a fallback until
// we render per-step screenshots through `scripts/generate-previews.ts`.
const HOWTO_IMAGE = heroImage;

const title = 'Open Design quickstart — Install in three commands (Node 24, pnpm)';
const description =
  'Install Open Design locally with three commands. Requirements (Node 24, pnpm 10.33.2), commands, expected output, troubleshooting, and how to generate your first design artifact with Claude Code, Codex, Cursor, Gemini, OpenCode, or Qwen.';

const steps = [
  {
    name: 'Clone and install',
    text: 'Clone the open-design repository and install workspace dependencies with pnpm. Requires Node 24 and pnpm 10.33.2 (use Corepack).',
    code: 'git clone https://github.com/nexu-io/open-design\ncd open-design\npnpm install',
  },
  {
    name: 'Start the daemon and web UI',
    text: 'Run tools-dev to start the local daemon and web runtime. This is the only lifecycle entry point — do not use the deprecated `pnpm dev` / `pnpm start` aliases.',
    code: 'pnpm tools-dev',
  },
  {
    name: 'Generate your first artifact',
    text: 'Open the web UI at http://127.0.0.1:17573 (or the port logged by tools-dev), pick a skill from the catalog, and let your agent render it. Or drive the daemon directly with the `od` CLI.',
    code: 'od skill run open-design-landing --output ./artifact.html',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Open Design', item: SITE },
      { '@type': 'ListItem', position: 2, name: 'Quickstart', item: `${SITE}quickstart/` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'Install Open Design in three commands',
    description,
    totalTime: 'PT5M',
    // Google's HowTo rich result requires an image at the top level
    // for SERP eligibility. Until per-step screenshots ship, we attach
    // the canonical hero image at both the root and each step.
    image: { '@type': 'ImageObject', url: HOWTO_IMAGE },
    tool: [
      { '@type': 'HowToTool', name: 'Node.js 24' },
      { '@type': 'HowToTool', name: 'pnpm 10.33.2 (Corepack)' },
      { '@type': 'HowToTool', name: 'git' },
    ],
    step: steps.map((s, idx) => ({
      '@type': 'HowToStep',
      position: idx + 1,
      name: s.name,
      text: s.text,
      image: { '@type': 'ImageObject', url: HOWTO_IMAGE },
      url: `${SITE}quickstart/#commands`,
    })),
  },
];
---

<Layout title={title} description={description} active="home" jsonLd={jsonLd}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href={href('/')}>Open Design</a>
    <span>/</span>
    <span aria-current="page">Quickstart</span>
  </nav>

  <article class="info-page">
    <header class="catalog-head">
      <span class="label">Install · Nº 01</span>
      <h1 class="display">
        Open Design <em>quickstart</em><span class="dot">.</span>
      </h1>
      <p class="lead">
        Open Design runs entirely on your machine. Three commands gets you
        from a clean checkout to a running daemon, web UI, and your first
        generated design artifact. Latest stable release:{' '}
        <a class="inline-link" href={REPO_RELEASES} target="_blank" rel="noreferrer noopener">{github.versionLabel}</a>.
      </p>
    </header>

    <section class="info-section" id="requirements">
      <h2>Requirements</h2>
      <ul>
        <li><strong>Node.js 24</strong> — install via <code>winget install OpenJS.NodeJS.LTS</code>, <code>brew install node@24</code>, or <a class="inline-link" href="https://nodejs.org" target="_blank" rel="noreferrer noopener">nodejs.org</a>. Node 22 is not supported.</li>
        <li><strong>pnpm 10.33.2</strong> — enabled through Corepack (<code>corepack enable</code>) so the lockfile-pinned version is used. On Windows, run <code>npm install -g pnpm@10.33.2</code> instead because Corepack hits EPERM under <code>Program Files</code>.</li>
        <li><strong>git</strong> — any recent version.</li>
        <li><strong>An agent</strong> — Claude Code, Codex, Cursor, Gemini CLI, OpenCode, or Qwen. See <a class="inline-link" href={href('/agents/')}>/agents/</a> for the full adapter list.</li>
      </ul>
    </section>

    <section class="info-section" id="commands">
      <h2>Three commands to ship</h2>
      <ol>
        {steps.map((s) => (
          <li>
            <strong>{s.name}.</strong> {s.text}
            <pre class="code-block"><code>{s.code}</code></pre>
          </li>
        ))}
      </ol>
      <p>
        Full notes live in <a class="inline-link" href={QUICKSTART_DOC} target="_blank" rel="noreferrer noopener">QUICKSTART.md</a>.
      </p>
    </section>

    <section class="info-section" id="expected-output">
      <h2>What you should see</h2>
      <p>
        When <code>pnpm tools-dev</code> is healthy, you'll see lines
        like these in the terminal — daemon, web runtime, and the
        sidecar IPC namespace are all reporting "ready":
      </p>
      <pre class="code-block"><code><span class="comment"># tools-dev — startup</span>
<span class="prompt">→</span> daemon  listening on http://127.0.0.1:17456 (namespace tools-dev/main)
<span class="prompt">→</span> web     listening on http://127.0.0.1:17573 (proxy → daemon)
<span class="prompt">→</span> sidecar /tmp/open-design/ipc/tools-dev-main/daemon.sock
<span class="prompt">→</span> ready in 1.4s</code></pre>
      <p>
        The exact ports come from your <code>tools-dev</code> flags
        (<code>--daemon-port</code>, <code>--web-port</code>); the
        defaults are stable across runs.
      </p>
    </section>

    <section class="info-section" id="troubleshooting">
      <h2>Troubleshooting</h2>
      <ul>
        <li><strong><code>EBADENGINE</code> on <code>pnpm install</code>:</strong> wrong Node major. <code>package.json#engines</code> pins <code>node: "~24"</code>. Switch with <code>nvm use 24</code> or reinstall Node 24.</li>
        <li><strong>better-sqlite3 build hangs on Windows:</strong> expected. Node 24 has no prebuilt binary on win32, so it compiles from source via node-gyp (~2 min). Install Visual Studio Build Tools 2022 first.</li>
        <li><strong>Port already in use:</strong> pass <code>--daemon-port</code> and <code>--web-port</code> to <code>pnpm tools-dev</code>, or stop the previous run with <code>pnpm tools-dev stop</code>.</li>
        <li><strong>Agent does not show up:</strong> see the agent adapter docs at <a class="inline-link" href={href('/agents/')}>/agents/</a>. Most adapters need a credential at <code>.od/media-config.json</code>.</li>
        <li><strong>Permission prompt loops:</strong> <code>pnpm tools-dev check</code> verifies your environment and prints what's missing.</li>
      </ul>
    </section>

    <section class="info-section" id="next">
      <h2>Next steps</h2>
      <ul>
        <li><a class="inline-link" href={href('/skills/')}>Browse the skill catalog</a> and pick one to render.</li>
        <li><a class="inline-link" href={href('/systems/')}>Pick a DESIGN.md system</a> so generated artifacts inherit a brand.</li>
        <li><a class="inline-link" href={href('/compare/')}>Compare Open Design to Claude Design, Figma Make, v0, and Lovable</a>.</li>
        <li><a class="inline-link" href={REPO_RELEASES} target="_blank" rel="noreferrer noopener">Subscribe to the GitHub releases feed</a> for new versions.</li>
      </ul>
    </section>

    {/* Closing CTA — keeps the documentation-heavy page from ending in
     * silence and gives Google a clear conversion signal. */}
    <section class="info-cta" aria-label="Open Design call to action">
      <div>
        <h2>Three commands. <em>Yours to keep.</em></h2>
        <p>
          You've read the install. Now star the repo so we know it
          helped, grab the desktop build, or hop into Discord if anything
          breaks on first run.
        </p>
      </div>
      <div class="info-cta-actions">
        <a class="btn btn-primary" href="https://github.com/nexu-io/open-design" target="_blank" rel="noreferrer noopener">Star on GitHub</a>
        <a class="btn btn-ghost" href={REPO_RELEASES} target="_blank" rel="noreferrer noopener">Download desktop</a>
        <a class="btn btn-ghost" href="https://discord.gg/9ptkbbqRu" target="_blank" rel="noreferrer noopener">Join Discord</a>
      </div>
      <div class="info-cta-meta">
        <span class="stamp">● Live</span>
        <span>{github.versionLabel} · Apache-2.0</span>
        <span>macOS · Windows · Linux</span>
      </div>
    </section>
  </article>
</Layout>
